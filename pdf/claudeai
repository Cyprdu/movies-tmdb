<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BookForge — Générateur de Livrets A5</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf-lib/1.17.1/pdf-lib.min.js"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=DM+Mono:wght@300;400;500&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&display=swap');

  :root {
    --ink: #0f0e0c;
    --paper: #faf8f4;
    --cream: #f2ede4;
    --gold: #c9a84c;
    --gold-light: #e8c97a;
    --rust: #8b3a2a;
    --sage: #4a5c4e;
    --muted: #7a7060;
    --border: #d8d0c0;
    --shadow: rgba(15,14,12,0.12);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--ink);
    color: var(--paper);
    font-family: 'DM Mono', monospace;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── GRAIN OVERLAY ── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 1000;
    opacity: 0.6;
  }

  /* ── HEADER ── */
  header {
    position: relative;
    padding: 5rem 4rem 3rem;
    border-bottom: 1px solid rgba(201,168,76,0.2);
    overflow: hidden;
  }

  header::after {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 320px; height: 320px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(201,168,76,0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .logo-mark {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    margin-bottom: 0.5rem;
  }

  .logo-mark span:first-child {
    font-family: 'Playfair Display', serif;
    font-weight: 900;
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    letter-spacing: -0.02em;
    color: var(--paper);
    line-height: 1;
  }

  .logo-mark span:last-child {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    color: var(--gold);
    text-transform: uppercase;
    padding: 0.2em 0.6em;
    border: 1px solid var(--gold);
    border-radius: 2px;
    margin-left: 0.4rem;
    vertical-align: middle;
  }

  .tagline {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 1.15rem;
    color: var(--muted);
    letter-spacing: 0.04em;
    margin-top: 0.3rem;
  }

  /* ── MAIN LAYOUT ── */
  main {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    min-height: calc(100vh - 180px);
  }

  /* ── LEFT PANEL ── */
  .panel-left {
    padding: 4rem;
    border-right: 1px solid rgba(201,168,76,0.15);
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .section-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.2rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .section-label::before {
    content: '';
    display: inline-block;
    width: 20px; height: 1px;
    background: var(--gold);
  }

  /* ── DROP ZONE ── */
  .drop-zone {
    position: relative;
    border: 1px solid rgba(201,168,76,0.3);
    border-radius: 4px;
    padding: 3.5rem 2rem;
    text-align: center;
    cursor: pointer;
    transition: all 0.35s ease;
    background: rgba(201,168,76,0.02);
    overflow: hidden;
  }

  .drop-zone::before {
    content: '';
    position: absolute;
    inset: 6px;
    border: 1px dashed rgba(201,168,76,0.15);
    border-radius: 2px;
    pointer-events: none;
    transition: border-color 0.3s ease;
  }

  .drop-zone:hover, .drop-zone.drag-over {
    border-color: var(--gold);
    background: rgba(201,168,76,0.05);
  }

  .drop-zone:hover::before, .drop-zone.drag-over::before {
    border-color: rgba(201,168,76,0.4);
  }

  .drop-icon {
    width: 52px;
    height: 52px;
    margin: 0 auto 1.5rem;
    position: relative;
  }

  .drop-icon svg {
    width: 100%;
    height: 100%;
    stroke: var(--gold);
    stroke-width: 1.2;
    fill: none;
  }

  .drop-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--paper);
    margin-bottom: 0.5rem;
  }

  .drop-sub {
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--muted);
    line-height: 1.7;
  }

  .drop-sub strong {
    color: var(--gold);
    font-weight: 400;
  }

  #file-input { display: none; }

  /* ── FILE INFO ── */
  .file-info {
    display: none;
    align-items: center;
    gap: 1.2rem;
    padding: 1.2rem 1.6rem;
    background: rgba(201,168,76,0.06);
    border: 1px solid rgba(201,168,76,0.2);
    border-radius: 3px;
    animation: slideIn 0.4s ease;
  }

  .file-info.visible { display: flex; }

  @keyframes slideIn {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .file-icon {
    width: 36px; height: 36px;
    background: rgba(201,168,76,0.1);
    border-radius: 3px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }

  .file-icon svg { stroke: var(--gold); width: 18px; height: 18px; }

  .file-details { flex: 1; min-width: 0; }
  .file-name {
    font-size: 0.8rem;
    color: var(--paper);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    margin-bottom: 0.2rem;
  }
  .file-meta { font-size: 0.65rem; color: var(--muted); letter-spacing: 0.05em; }

  .file-remove {
    cursor: pointer;
    color: var(--muted);
    padding: 4px;
    border-radius: 2px;
    transition: color 0.2s;
    background: none; border: none;
    line-height: 1;
  }
  .file-remove:hover { color: var(--rust); }

  /* ── SETTINGS ── */
  .settings-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .field.full { grid-column: 1 / -1; }

  .field label {
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .field select, .field input[type="text"] {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(201,168,76,0.2);
    color: var(--paper);
    font-family: 'DM Mono', monospace;
    font-size: 0.78rem;
    padding: 0.7rem 1rem;
    border-radius: 3px;
    outline: none;
    transition: border-color 0.25s;
    -webkit-appearance: none;
    appearance: none;
    cursor: pointer;
  }

  .field select:focus, .field input[type="text"]:focus {
    border-color: var(--gold);
  }

  .field select option {
    background: #1a1916;
  }

  /* Toggle */
  .toggle-group {
    display: flex;
    border: 1px solid rgba(201,168,76,0.2);
    border-radius: 3px;
    overflow: hidden;
  }

  .toggle-group label {
    flex: 1;
    text-align: center;
    padding: 0.65rem 0.5rem;
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: all 0.25s;
    color: var(--muted);
    user-select: none;
  }

  .toggle-group input[type="radio"] { display: none; }

  .toggle-group input[type="radio"]:checked + label {
    background: rgba(201,168,76,0.12);
    color: var(--gold);
  }

  /* ── IMPOSITION PREVIEW ── */
  .imposition-preview {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(201,168,76,0.12);
    border-radius: 4px;
    padding: 1.6rem;
  }

  .preview-title {
    font-family: 'Playfair Display', serif;
    font-size: 0.95rem;
    color: var(--paper);
    margin-bottom: 1.2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .preview-title span {
    font-family: 'DM Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    color: var(--muted);
  }

  .sheet-diagram {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-height: 220px;
    overflow-y: auto;
  }

  .sheet-diagram::-webkit-scrollbar { width: 3px; }
  .sheet-diagram::-webkit-scrollbar-track { background: transparent; }
  .sheet-diagram::-webkit-scrollbar-thumb { background: rgba(201,168,76,0.3); border-radius: 2px; }

  .sheet-row {
    display: grid;
    grid-template-columns: 60px 1fr 1fr;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.65rem;
    padding: 0.4rem 0.6rem;
    background: rgba(255,255,255,0.02);
    border-radius: 2px;
    transition: background 0.2s;
  }

  .sheet-row:hover { background: rgba(201,168,76,0.04); }

  .sheet-row-label {
    color: var(--muted);
    letter-spacing: 0.1em;
  }

  .sheet-page {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
  }

  .page-box {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px; height: 36px;
    border: 1px solid rgba(201,168,76,0.25);
    border-radius: 2px;
    font-size: 0.7rem;
    color: var(--paper);
    background: rgba(201,168,76,0.05);
    position: relative;
    transition: all 0.2s;
  }

  .page-box:hover {
    border-color: var(--gold);
    background: rgba(201,168,76,0.1);
  }

  .sheet-separator {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--muted);
    font-size: 0.55rem;
    letter-spacing: 0.15em;
    margin: 0.2rem 0;
  }

  .sheet-separator::before, .sheet-separator::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(201,168,76,0.1);
  }

  /* ── CTA BUTTON ── */
  .cta-wrapper {
    margin-top: auto;
    padding-top: 1rem;
  }

  .btn-generate {
    width: 100%;
    padding: 1.1rem 2rem;
    background: var(--gold);
    color: var(--ink);
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    border: none;
    border-radius: 3px;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .btn-generate::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.15), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .btn-generate:hover:not(:disabled) {
    background: var(--gold-light);
    transform: translateY(-1px);
    box-shadow: 0 8px 30px rgba(201,168,76,0.25);
  }

  .btn-generate:hover::before { opacity: 1; }

  .btn-generate:disabled {
    opacity: 0.35;
    cursor: not-allowed;
    transform: none;
  }

  .btn-generate.loading {
    color: transparent;
  }

  .btn-generate.loading::after {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 18px; height: 18px;
    border: 2px solid var(--ink);
    border-top-color: transparent;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }

  @keyframes spin { to { transform: translate(-50%, -50%) rotate(360deg); } }

  /* ── RIGHT PANEL ── */
  .panel-right {
    padding: 4rem;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* ── VISUAL EXPLANATION ── */
  .explainer {
    flex: 1;
  }

  .explainer h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.6rem, 2.5vw, 2.2rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--paper);
    margin-bottom: 0.8rem;
  }

  .explainer h2 em {
    font-style: italic;
    color: var(--gold);
  }

  .explainer p {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1rem;
    font-weight: 300;
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  /* ── IMPOSITION VISUAL ── */
  .imposition-visual {
    position: relative;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(201,168,76,0.1);
    border-radius: 6px;
    padding: 2rem;
    overflow: hidden;
  }

  .imposition-visual::before {
    content: 'IMPOSITION';
    position: absolute;
    top: 1rem; right: 1.5rem;
    font-size: 0.55rem;
    letter-spacing: 0.3em;
    color: rgba(201,168,76,0.25);
  }

  .a4-sheet {
    width: 100%;
    aspect-ratio: 297/210;
    border: 1.5px solid rgba(201,168,76,0.4);
    border-radius: 3px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
    background: rgba(255,255,255,0.01);
    overflow: hidden;
  }

  .a4-sheet::before {
    content: '';
    position: absolute;
    left: 50%; top: 0; bottom: 0;
    width: 1px;
    background: rgba(201,168,76,0.3);
    z-index: 2;
  }

  .a4-page {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1rem;
    position: relative;
  }

  .a4-page:first-child { border-right: none; }

  .page-label-num {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.2rem, 2.5vw, 2rem);
    font-weight: 700;
    color: var(--paper);
    line-height: 1;
  }

  .page-label-text {
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    color: var(--gold);
    text-transform: uppercase;
  }

  .fold-arrow {
    position: absolute;
    left: 50%; top: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.55rem;
    letter-spacing: 0.15em;
    color: rgba(201,168,76,0.5);
    white-space: nowrap;
    z-index: 3;
    padding: 0.2rem 0.6rem;
    background: rgba(15,14,12,0.8);
  }

  /* ── STATUS ── */
  .status-panel {
    display: none;
    padding: 1.2rem 1.6rem;
    border-radius: 3px;
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    animation: slideIn 0.3s ease;
    line-height: 1.6;
  }

  .status-panel.visible { display: block; }

  .status-panel.info {
    background: rgba(74,92,78,0.12);
    border: 1px solid rgba(74,92,78,0.3);
    color: #8aab8f;
  }

  .status-panel.success {
    background: rgba(201,168,76,0.08);
    border: 1px solid rgba(201,168,76,0.25);
    color: var(--gold);
  }

  .status-panel.error {
    background: rgba(139,58,42,0.12);
    border: 1px solid rgba(139,58,42,0.3);
    color: #d4836e;
  }

  .progress-bar {
    height: 2px;
    background: rgba(255,255,255,0.06);
    border-radius: 1px;
    margin-top: 0.8rem;
    overflow: hidden;
    display: none;
  }

  .progress-bar.visible { display: block; }

  .progress-fill {
    height: 100%;
    background: var(--gold);
    border-radius: 1px;
    transition: width 0.4s ease;
    width: 0%;
  }

  /* ── SPECS ── */
  .specs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.8rem;
  }

  .spec-item {
    padding: 1rem;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(201,168,76,0.1);
    border-radius: 3px;
    text-align: center;
  }

  .spec-num {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--paper);
    line-height: 1;
    margin-bottom: 0.3rem;
  }

  .spec-label {
    font-size: 0.58rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* ── FOOTER ── */
  footer {
    border-top: 1px solid rgba(201,168,76,0.1);
    padding: 1.5rem 4rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-note {
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    color: rgba(122,112,96,0.5);
  }

  .footer-tech {
    display: flex;
    gap: 1rem;
  }

  .tech-badge {
    font-size: 0.58rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(201,168,76,0.3);
    padding: 0.25em 0.6em;
    border: 1px solid rgba(201,168,76,0.12);
    border-radius: 2px;
  }

  /* ── DOWNLOAD BTN ── */
  .btn-download {
    display: none;
    width: 100%;
    padding: 1rem 2rem;
    background: transparent;
    color: var(--gold);
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    border: 1px solid var(--gold);
    border-radius: 3px;
    cursor: pointer;
    text-decoration: none;
    text-align: center;
    transition: all 0.3s ease;
    margin-top: 0.8rem;
    animation: slideIn 0.4s ease;
  }

  .btn-download.visible { display: block; }
  .btn-download:hover {
    background: rgba(201,168,76,0.08);
    box-shadow: 0 4px 20px rgba(201,168,76,0.12);
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    main { grid-template-columns: 1fr; }
    .panel-left { border-right: none; border-bottom: 1px solid rgba(201,168,76,0.15); }
    header { padding: 3rem 2rem 2rem; }
    .panel-left, .panel-right { padding: 2.5rem 2rem; }
    footer { padding: 1.5rem 2rem; flex-direction: column; gap: 0.8rem; }
    .specs { grid-template-columns: repeat(3, 1fr); }
  }
</style>
</head>
<body>

<header>
  <div class="logo-mark">
    <span>BookForge</span>
    <span>A5 Imposition</span>
  </div>
  <p class="tagline">Transformez votre PDF en livret imprimable — imposition professionnelle automatique</p>
</header>

<main>
  <!-- ══ LEFT PANEL ══ -->
  <div class="panel-left">

    <div>
      <div class="section-label">Source Document</div>
      <div class="drop-zone" id="drop-zone">
        <input type="file" id="file-input" accept=".pdf">
        <div class="drop-icon">
          <svg viewBox="0 0 24 24">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="12" y1="18" x2="12" y2="12"/>
            <polyline points="9 15 12 12 15 15"/>
          </svg>
        </div>
        <div class="drop-title">Déposez votre PDF</div>
        <div class="drop-sub">
          Glisser-déposer ou <strong>cliquer pour parcourir</strong><br>
          Fichiers PDF uniquement · Toutes tailles acceptées
        </div>
      </div>

      <div class="file-info" id="file-info">
        <div class="file-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
          </svg>
        </div>
        <div class="file-details">
          <div class="file-name" id="file-name">—</div>
          <div class="file-meta" id="file-meta">— · —</div>
        </div>
        <button class="file-remove" id="file-remove" title="Supprimer">✕</button>
      </div>
    </div>

    <div>
      <div class="section-label">Configuration</div>
      <div class="settings-grid">
        <div class="field">
          <label>Orientation impression</label>
          <select id="binding-side">
            <option value="left">Reliure gauche</option>
            <option value="right">Reliure droite</option>
          </select>
        </div>
        <div class="field">
          <label>Complétion pages</label>
          <select id="padding-mode">
            <option value="blank">Pages blanches</option>
            <option value="none">Aucune</option>
          </select>
        </div>
        <div class="field full">
          <label>Titre du livret (optionnel)</label>
          <input type="text" id="booklet-title" placeholder="Mon Livret...">
        </div>
        <div class="field full">
          <label>Ordre des feuilles à l'impression</label>
          <div class="toggle-group">
            <input type="radio" name="print-order" id="order-normal" value="normal" checked>
            <label for="order-normal">Normal</label>
            <input type="radio" name="print-order" id="order-reverse" value="reverse">
            <label for="order-reverse">Inversé (recto-verso auto)</label>
          </div>
        </div>
      </div>
    </div>

    <div id="imposition-section">
      <div class="section-label">Plan d'imposition</div>
      <div class="imposition-preview">
        <div class="preview-title">
          Ordre des pages
          <span id="sheet-count-label">— feuilles</span>
        </div>
        <div class="sheet-diagram" id="sheet-diagram">
          <div style="text-align:center; padding: 1.5rem; font-size:0.68rem; color:var(--muted);">
            Chargez un PDF pour<br>visualiser l'imposition
          </div>
        </div>
      </div>
    </div>

    <div class="cta-wrapper">
      <div class="status-panel" id="status-panel"></div>
      <div class="progress-bar" id="progress-bar">
        <div class="progress-fill" id="progress-fill"></div>
      </div>
      <button class="btn-generate" id="btn-generate" disabled>
        Générer le Livret
      </button>
      <a class="btn-download" id="btn-download" download="livret-a5.pdf">
        ↓ Télécharger le livret PDF
      </a>
    </div>

  </div>

  <!-- ══ RIGHT PANEL ══ -->
  <div class="panel-right">

    <div class="explainer">
      <p class="section-label" style="margin-bottom:1.2rem;">Comment ça fonctionne</p>
      <h2>Imposition <em>automatique</em><br>pour livrets A5</h2>
      <p>
        BookForge réorganise les pages de votre PDF selon le principe de l'imposition typographique :
        chaque feuille A4 imprimée recto-verso contient deux pages A5, qui formeront un livret une fois pliées et agrafées.
      </p>

      <div class="imposition-visual">
        <div class="a4-sheet">
          <div class="a4-page">
            <div class="page-label-num" id="vis-left">16</div>
            <div class="page-label-text">Verso · Gauche</div>
          </div>
          <div class="a4-page">
            <div class="page-label-num" id="vis-right">1</div>
            <div class="page-label-text">Recto · Droite</div>
          </div>
        </div>
        <div style="text-align:center; margin-top:0.8rem; font-size:0.62rem; color:var(--muted); letter-spacing:0.1em;">
          FACE RECTO — Feuille 1 / Face extérieure
        </div>
      </div>
    </div>

    <div class="specs">
      <div class="spec-item">
        <div class="spec-num" id="spec-pages">—</div>
        <div class="spec-label">Pages source</div>
      </div>
      <div class="spec-item">
        <div class="spec-num" id="spec-sheets">—</div>
        <div class="spec-label">Feuilles A4</div>
      </div>
      <div class="spec-item">
        <div class="spec-num" id="spec-total">—</div>
        <div class="spec-label">Pages livret</div>
      </div>
    </div>

  </div>
</main>

<footer>
  <div class="footer-note">Traitement 100% local · Aucune donnée transmise · Confidentialité totale</div>
  <div class="footer-tech">
    <span class="tech-badge">pdf-lib 1.17</span>
    <span class="tech-badge">A5 · A4</span>
    <span class="tech-badge">Imposition</span>
  </div>
</footer>

<script>
// ══════════════════════════════════════════════
//  BookForge — Booklet Imposition Engine
// ══════════════════════════════════════════════

const { PDFDocument, degrees } = PDFLib;

let pdfFile = null;
let pdfBytes = null;
let totalPages = 0;

const dropZone = document.getElementById('drop-zone');
const fileInput = document.getElementById('file-input');
const fileInfo = document.getElementById('file-info');
const fileName = document.getElementById('file-name');
const fileMeta = document.getElementById('file-meta');
const fileRemove = document.getElementById('file-remove');
const btnGenerate = document.getElementById('btn-generate');
const btnDownload = document.getElementById('btn-download');
const statusPanel = document.getElementById('status-panel');
const progressBar = document.getElementById('progress-bar');
const progressFill = document.getElementById('progress-fill');
const sheetDiagram = document.getElementById('sheet-diagram');
const sheetCountLabel = document.getElementById('sheet-count-label');
const specPages = document.getElementById('spec-pages');
const specSheets = document.getElementById('spec-sheets');
const specTotal = document.getElementById('spec-total');
const visLeft = document.getElementById('vis-left');
const visRight = document.getElementById('vis-right');

// ── FILE HANDLING ──
dropZone.addEventListener('click', () => fileInput.click());
dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
dropZone.addEventListener('drop', e => {
  e.preventDefault();
  dropZone.classList.remove('drag-over');
  const file = e.dataTransfer.files[0];
  if (file && file.type === 'application/pdf') handleFile(file);
  else showStatus('Veuillez déposer un fichier PDF valide.', 'error');
});
fileInput.addEventListener('change', () => {
  if (fileInput.files[0]) handleFile(fileInput.files[0]);
});
fileRemove.addEventListener('click', resetFile);

async function handleFile(file) {
  pdfFile = file;
  showStatus('Lecture du fichier…', 'info');

  const reader = new FileReader();
  reader.onload = async (e) => {
    try {
      pdfBytes = new Uint8Array(e.target.result);
      const doc = await PDFDocument.load(pdfBytes);
      totalPages = doc.getPageCount();

      const sizeKB = Math.round(file.size / 1024);
      fileName.textContent = file.name;
      fileMeta.textContent = `${totalPages} pages · ${sizeKB < 1024 ? sizeKB + ' Ko' : (sizeKB/1024).toFixed(1) + ' Mo'}`;

      fileInfo.classList.add('visible');
      dropZone.style.display = 'none';

      updateImpositionData();
      statusPanel.classList.remove('visible');
      btnGenerate.disabled = false;
    } catch (err) {
      showStatus('Impossible de lire ce fichier PDF. Vérifiez qu\'il n\'est pas protégé.', 'error');
      resetFile();
    }
  };
  reader.readAsArrayBuffer(file);
}

function resetFile() {
  pdfFile = null; pdfBytes = null; totalPages = 0;
  fileInfo.classList.remove('visible');
  dropZone.style.display = '';
  fileInput.value = '';
  btnGenerate.disabled = true;
  btnDownload.classList.remove('visible');
  statusPanel.classList.remove('visible');
  progressBar.classList.remove('visible');
  sheetDiagram.innerHTML = '<div style="text-align:center;padding:1.5rem;font-size:0.68rem;color:var(--muted);">Chargez un PDF pour<br>visualiser l\'imposition</div>';
  sheetCountLabel.textContent = '— feuilles';
  specPages.textContent = '—'; specSheets.textContent = '—'; specTotal.textContent = '—';
  visLeft.textContent = '16'; visRight.textContent = '1';
}

// ── IMPOSITION MATH ──
function computeBookletOrder(n) {
  // Pad to multiple of 4
  const padded = Math.ceil(n / 4) * 4;
  const sheets = [];
  let lo = 1, hi = padded;
  while (lo < hi) {
    sheets.push({ recto: [hi, lo], verso: [lo + 1, hi - 1] });
    lo += 2; hi -= 2;
  }
  return { sheets, padded };
}

function updateImpositionData() {
  if (!totalPages) return;
  const { sheets, padded } = computeBookletOrder(totalPages);
  const numSheets = sheets.length;

  specPages.textContent = totalPages;
  specSheets.textContent = numSheets;
  specTotal.textContent = padded;
  sheetCountLabel.textContent = numSheets + ' feuille' + (numSheets > 1 ? 's' : '');

  visLeft.textContent = padded;
  visRight.textContent = '1';

  // Build diagram
  sheetDiagram.innerHTML = '';
  sheets.forEach((sh, i) => {
    if (i > 0) {
      const sep = document.createElement('div');
      sep.className = 'sheet-separator';
      sep.textContent = `Feuille ${i + 1}`;
      sheetDiagram.appendChild(sep);
    } else {
      const sep = document.createElement('div');
      sep.className = 'sheet-separator';
      sep.textContent = `Feuille 1`;
      sheetDiagram.appendChild(sep);
    }

    // Recto
    const recto = makeSheetRow('Recto', sh.recto[0], sh.recto[1], totalPages, padded);
    sheetDiagram.appendChild(recto);

    // Verso
    const verso = makeSheetRow('Verso', sh.verso[0], sh.verso[1], totalPages, padded);
    sheetDiagram.appendChild(verso);
  });
}

function makeSheetRow(label, left, right, total, padded) {
  const row = document.createElement('div');
  row.className = 'sheet-row';

  const lbl = document.createElement('div');
  lbl.className = 'sheet-row-label';
  lbl.textContent = label;

  const leftCell = document.createElement('div');
  leftCell.className = 'sheet-page';
  const lb = document.createElement('div');
  lb.className = 'page-box';
  lb.textContent = left > total ? '—' : left;
  if (left > total) lb.style.opacity = '0.3';
  leftCell.appendChild(lb);
  leftCell.insertAdjacentHTML('afterbegin', '<span style="font-size:0.55rem;color:var(--muted);letter-spacing:0.08em;margin-right:0.2rem">◀</span>');

  const rightCell = document.createElement('div');
  rightCell.className = 'sheet-page';
  const rb = document.createElement('div');
  rb.className = 'page-box';
  rb.textContent = right > total ? '—' : right;
  if (right > total) rb.style.opacity = '0.3';
  rightCell.appendChild(rb);
  rightCell.insertAdjacentHTML('beforeend', '<span style="font-size:0.55rem;color:var(--muted);letter-spacing:0.08em;margin-left:0.2rem">▶</span>');

  row.appendChild(lbl);
  row.appendChild(leftCell);
  row.appendChild(rightCell);
  return row;
}

// ── STATUS ──
function showStatus(msg, type = 'info') {
  statusPanel.textContent = msg;
  statusPanel.className = 'status-panel visible ' + type;
}

function setProgress(pct) {
  progressBar.classList.add('visible');
  progressFill.style.width = pct + '%';
}

// ── GENERATE ──
btnGenerate.addEventListener('click', generateBooklet);

async function generateBooklet() {
  if (!pdfBytes) return;

  btnGenerate.classList.add('loading');
  btnGenerate.disabled = true;
  btnDownload.classList.remove('visible');
  showStatus('Initialisation de l\'imposition…', 'info');
  setProgress(5);

  try {
    const sourceDoc = await PDFDocument.load(pdfBytes);
    const n = sourceDoc.getPageCount();
    const { sheets, padded } = computeBookletOrder(n);

    showStatus('Analyse des pages source…', 'info');
    setProgress(15);

    // Create output doc
    const outDoc = await PDFDocument.create();

    // A4 landscape dimensions (in points, 1pt = 1/72 inch)
    // A4: 595.28 x 841.89 pt  → landscape: 841.89 x 595.28
    const A4W = 841.89;
    const A4H = 595.28;
    const halfW = A4W / 2;

    const totalSheets = sheets.length;
    let step = 0;
    const totalSteps = totalSheets * 2; // recto + verso per sheet

    const printReverse = document.querySelector('input[name="print-order"]:checked').value === 'reverse';
    const sheetsOrdered = printReverse ? [...sheets].reverse() : sheets;

    for (const sh of sheetsOrdered) {
      // RECTO (face 1): left = sh.recto[0], right = sh.recto[1]
      await addImposedPage(outDoc, sourceDoc, sh.recto[0], sh.recto[1], A4W, A4H, halfW, padded);
      step++;
      setProgress(15 + Math.round((step / totalSteps) * 75));

      // VERSO (face 2): left = sh.verso[0], right = sh.verso[1]
      await addImposedPage(outDoc, sourceDoc, sh.verso[0], sh.verso[1], A4W, A4H, halfW, padded);
      step++;
      setProgress(15 + Math.round((step / totalSteps) * 75));
    }

    showStatus('Finalisation du PDF…', 'info');
    setProgress(92);

    const outBytes = await outDoc.save();
    const blob = new Blob([outBytes], { type: 'application/pdf' });
    const url = URL.createObjectURL(blob);

    btnDownload.href = url;
    const title = document.getElementById('booklet-title').value.trim();
    btnDownload.download = title ? title.replace(/\s+/g, '-') + '-livret.pdf' : 'livret-a5.pdf';
    btnDownload.classList.add('visible');

    setProgress(100);
    showStatus(`✓ Livret généré · ${totalSheets * 2} pages A4 · ${n} pages utiles · Prêt à imprimer`, 'success');

  } catch (err) {
    showStatus('Erreur lors de la génération : ' + err.message, 'error');
    console.error(err);
  } finally {
    btnGenerate.classList.remove('loading');
    btnGenerate.disabled = false;
  }
}

async function addImposedPage(outDoc, sourceDoc, leftPageNum, rightPageNum, A4W, A4H, halfW, padded) {
  const n = sourceDoc.getPageCount();
  const page = outDoc.addPage([A4W, A4H]);

  // Embed and draw left page
  if (leftPageNum >= 1 && leftPageNum <= n) {
    const [embLeft] = await outDoc.embedPdf(sourceDoc, [leftPageNum - 1]);
    const srcPage = sourceDoc.getPage(leftPageNum - 1);
    const { width: sw, height: sh } = srcPage.getSize();

    // Scale to fit halfW x A4H, maintaining aspect ratio
    const scale = Math.min(halfW / sw, A4H / sh);
    const dw = sw * scale;
    const dh = sh * scale;
    const dx = (halfW - dw) / 2;
    const dy = (A4H - dh) / 2;

    page.drawPage(embLeft, { x: dx, y: dy, width: dw, height: dh });
  }

  // Embed and draw right page
  if (rightPageNum >= 1 && rightPageNum <= n) {
    const [embRight] = await outDoc.embedPdf(sourceDoc, [rightPageNum - 1]);
    const srcPage = sourceDoc.getPage(rightPageNum - 1);
    const { width: sw, height: sh } = srcPage.getSize();

    const scale = Math.min(halfW / sw, A4H / sh);
    const dw = sw * scale;
    const dh = sh * scale;
    const dx = halfW + (halfW - dw) / 2;
    const dy = (A4H - dh) / 2;

    page.drawPage(embRight, { x: dx, y: dy, width: dw, height: dh });
  }

  // Draw center fold line (thin, subtle)
  page.drawLine({
    start: { x: halfW, y: 0 },
    end: { x: halfW, y: A4H },
    thickness: 0.4,
    color: PDFLib.rgb(0.7, 0.7, 0.7),
    dashArray: [4, 4],
    dashPhase: 0,
  });
}

// Watch for settings changes to update imposition
document.querySelectorAll('select, input[type="radio"]').forEach(el => {
  el.addEventListener('change', updateImpositionData);
});
</script>
</body>
